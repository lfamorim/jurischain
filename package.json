{
  "name": "@credithub/jurischain",
  "version": "1.1.2",
  "description": "Instead of challenging the humans at the terminals, it would be better to challenge the terminals. It is about balancing the load with customers so as not to suffer a DDoS attack. Inspired by blockchain technology.",
  "main": "dist/jurischain-bundle.js",
  "browser": "dist/jurischain-bundle.js",
  "types": "index.d.ts",
  "files": [
    "dist/jurischain-bundle.js",
    "index.d.ts",
    "LICENSE"
  ],
  "scripts": {
    "build": "./build.sh build",
    "transpile": "babel dist/jurischain-bundle.js -o dist/jurischain-bundle.js",
    "minify": "npm run transpile && terser dist/jurischain-bundle.js --ecma 5 --compress passes=3,dead_code,collapse_vars,reduce_vars --mangle -o dist/jurischain-bundle.js",
    "postbuild": "npm run minify",
    "test": "npm run test:browser",
    "test:browser": "npx playwright test",
    "test:docker": "./build.sh test",
    "prepublishOnly": "npm run minify && npm run test:browser",
    "prepack": "npm run minify && npm run test:browser"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/credithub/jurischain.git"
  },
  "keywords": [
    "captcha",
    "proof-of-work",
    "jurischain",
    "blockchain"
  ],
  "author": "CreditHub <tech@credithub.com.br>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/credithub/jurischain/issues"
  },
  "homepage": "https://github.com/credithub/jurischain#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.13",
    "@types/human-interval": "^1.0.0",
    "@types/jest": "^27.0.2",
    "@types/node": "^16.11.6",
    "@types/selenium-webdriver": "^4.0.16",
    "express": "^4.17.1",
    "human-interval": "^2.0.1",
    "jest": "^27.3.1",
    "ngrok": "^4.2.2",
    "playwright": "^1.59.1",
    "selenium-webdriver": "^4.0.0",
    "serve": "^14.2.6",
    "terser": "^5.46.1",
    "ts-jest": "^27.0.7",
    "typescript": "^4.4.4"
  }
}
