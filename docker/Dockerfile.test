# =============================================================================
# JurisChain - Multi-Interface Test Dockerfile
# Builds and tests: PHP 8 extension, Node.js native addon, Python, ASM.js CLI
# =============================================================================

# -----------------------------------------------------------------------------
# Stage: PHP 8 Extension Build + Test
# -----------------------------------------------------------------------------
FROM php:8.3-cli AS test-php

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc make autoconf && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY include/jurischain.h /usr/local/include/jurischain.h
COPY include/jurischain.h /src/jurischain.h
COPY bindings/php/ /src/ext/
WORKDIR /src/ext

RUN phpize && \
    ./configure --enable-jurischain CFLAGS="-I/usr/local/include" && \
    make -j$(nproc) && \
    make install && \
    docker-php-ext-enable jurischain

RUN php -m | grep jurischain

COPY tests/test_php.php /src/tests/test_php.php
CMD ["php", "-d", "assert.exception=1", "/src/tests/test_php.php"]

# -----------------------------------------------------------------------------
# Stage: Node.js Native Addon Build + Test
# -----------------------------------------------------------------------------
FROM node:20-slim AS test-node

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY bindings/node/ /src/bindings/node/
COPY include/jurischain.h /src/bindings/node/jurischain.h

WORKDIR /src/bindings/node
RUN npm install

COPY tests/test_node.js /src/tests/test_node.js

CMD ["node", "/src/tests/test_node.js"]

# -----------------------------------------------------------------------------
# Stage: Python Smoke Test
# -----------------------------------------------------------------------------
FROM python:3.12-slim AS test-python

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc make nodejs npm && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY include/ /src/include/
COPY src/cli.c /src/src/cli.c
COPY Makefile /src/
COPY scripts/genstats.py /src/scripts/genstats.py
COPY requirements.txt /src/
COPY dist/ /src/dist/
COPY tests/test_python.py /src/tests/test_python.py

RUN make cli CFLAGS="-O3" || echo "Native CLI build skipped (may need specific arch flags)"

RUN pip install --no-cache-dir matplotlib

CMD ["python3", "/src/tests/test_python.py"]
